OPENAI_API_KEY=your_key_here
LLM_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAW_DATA_DIR=data/raw
PROCESSED_DIR=data/processed
INDEX_DIR=data/index
CHUNK_SIZE=400
CHUNK_OVERLAP=60
TOP_K=5
RRF_K=60
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
ENABLE_RERANKER=true
ENABLE_QUERY_REWRITING=true
CHUNKING_STRATEGY=word
RATE_LIMIT=20/minute
# RAG_API_KEY=your_api_key_here

# Advanced features
ENABLE_HYDE=false
ENABLE_PARENT_CHILD=false
PARENT_CHUNK_SIZE=800
CHILD_CHUNK_SIZE=200
ENABLE_SEMANTIC_CACHE=false
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_TTL=3600
# REDIS_URL=redis://localhost:6379
ENABLE_GUARDRAILS=true
ENABLE_ADAPTIVE_RETRIEVAL=false
ENABLE_CONTEXTUAL_COMPRESSION=false
COMPRESSION_TYPE=embedding

# Conversation memory
ENABLE_CONVERSATION_MEMORY=false
MEMORY_MAX_TURNS=5
MEMORY_TTL=3600

# Observability
OTLP_ENDPOINT=http://otel-collector:4317
LOG_LEVEL=INFO
LOG_JSON=true

# To use Ollama instead of OpenAI:
# OPENAI_API_KEY=ollama
# LLM_MODEL=llama3.2:3b
# OPENAI_BASE_URL=http://localhost:11434/v1           # local development
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1  # Docker (Ollama runs on host)
