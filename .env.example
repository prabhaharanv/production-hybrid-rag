OPENAI_API_KEY=your_key_here
LLM_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAW_DATA_DIR=data/raw
PROCESSED_DIR=data/processed
INDEX_DIR=data/index
CHUNK_SIZE=400
CHUNK_OVERLAP=60
TOP_K=5
RRF_K=60

