{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(rag_requests_total[5m]))",
          "legendFormat": "total"
        },
        {
          "expr": "sum(rate(rag_requests_total{status=\"error\"}[5m]))",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "title": "Request Latency Percentiles",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(rag_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Pipeline Step Latency (p95)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_step_latency_seconds_bucket[5m])) by (le, step))",
          "legendFormat": "{{ step }}"
        }
      ]
    },
    {
      "title": "Abstention Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(rag_abstentions_total[5m])) / sum(rate(rag_requests_total{status=\"success\"}[5m]))",
          "legendFormat": "abstention rate"
        }
      ]
    },
    {
      "title": "Top Retrieval Score Distribution",
      "type": "histogram",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "sum(rate(rag_retrieval_top_score_bucket[5m])) by (le)",
          "legendFormat": "{{ le }}"
        }
      ]
    },
    {
      "title": "Token Usage (rate/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "sum(rate(rag_token_usage_total[5m])) by (type)",
          "legendFormat": "{{ type }}"
        }
      ]
    },
    {
      "title": "Pipeline Readiness",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 24},
      "targets": [
        {
          "expr": "rag_pipeline_ready",
          "legendFormat": "ready"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "title": "Chunks Retrieved (avg)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 24},
      "targets": [
        {
          "expr": "sum(rate(rag_chunks_retrieved_sum[5m])) / sum(rate(rag_chunks_retrieved_count[5m]))",
          "legendFormat": "avg chunks"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["rag", "observability"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "title": "RAG API Dashboard",
  "uid": "rag-api-dashboard"
}
